# Meta-Harness environment variables. Copy to .env and fill in.

# Anthropic API key — required for inner-loop LLM calls (BUILD_ORDER step 3+)
# and proposer subprocess calls (step 6+). Subscription auth via the `claude`
# CLI is also supported; see backend/app/meta_harness/proposer.py for the
# precedence rules (mirrors Stanford's claude_wrapper.py).
ANTHROPIC_API_KEY=

# Postgres DSN — must match infra/docker-compose.yml.
POSTGRES_DSN=postgresql://meta_harness:meta_harness@localhost:5432/meta_harness
